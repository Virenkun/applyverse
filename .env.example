# Copy to .env and adjust as needed.

# Postgres (compose maps host port 5433 -> container 5432)
DATABASE_URL=postgresql+psycopg://jobscrap:jobscrap@localhost:5433/jobscrap
REDIS_URL=redis://localhost:6380/0

# Scrape intervals (hours)
SCRAPE_INTERVAL_EASY_HOURS=4
SCRAPE_INTERVAL_HARD_HOURS=6

# Hard sources — Naukri needs real Chrome on the worker host; Wellfound is
# currently DataDome-blocked (best effort)
ENABLE_NAUKRI=true
ENABLE_WELLFOUND=true
# LinkedIn guest search — ToS risk, aggressive rate limits; low volume only
ENABLE_LINKEDIN=false

# Optional: enables LLM-assisted company discovery (Claude + web search)
# ANTHROPIC_API_KEY=sk-ant-...

# Role keywords (comma separated). Two jobs:
#  1. keyword sources (Naukri/Wellfound) search these terms
#  2. EVERY scraped job is kept only if its title/tags contain one of them
# Leave empty to keep everything.
SEARCH_KEYWORDS=software engineer,software developer,developer,full stack,backend,frontend,front end,back end,devops,sde,data engineer
SEARCH_LOCATION=india

# Dashboard access password (login page). Change it.
APPLYVERSE_PASSWORD=applyverse
