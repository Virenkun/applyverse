# Copy to .env and adjust as needed.

# Postgres (compose maps host port 5433 -> container 5432)
DATABASE_URL=postgresql+psycopg://jobscrap:jobscrap@localhost:5433/jobscrap
REDIS_URL=redis://localhost:6380/0

# Scrape intervals (hours)
SCRAPE_INTERVAL_EASY_HOURS=4
SCRAPE_INTERVAL_HARD_HOURS=6

# Hard sources are off by default — enable once verified working from your IP
ENABLE_NAUKRI=false
ENABLE_WELLFOUND=false

# Keyword queries used by Naukri/Wellfound search-based scrapers (comma separated)
SEARCH_KEYWORDS=software engineer,full stack developer
SEARCH_LOCATION=india
